{
  "name": "openwiki",
  "version": "0.1.2",
  "description": "A CLI that uses a DeepAgents documentation agent to generate and maintain an OpenWiki for a codebase.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "bun": ">=1.0.0"
  },
  "bin": {
    "openwiki": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "ai",
    "agents",
    "documentation",
    "wiki",
    "deepagents",
    "langchain",
    "cli"
  ],
  "scripts": {
    "openwiki": "bun run dist/cli.js",
    "build": "tsc -p tsconfig.json",
    "clean": "bun -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "coverage": "vitest run --coverage",
    "dev": "bun run src/cli.tsx",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "prebuild": "bun run clean",
    "prepack": "bun run build",
    "start": "bun run dist/cli.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1080.0",
    "@langchain/anthropic": "^1.5.1",
    "@langchain/aws": "^1.4.2",
    "@langchain/core": "^1.2.1",
    "@langchain/langgraph-checkpoint": "^1.1.2",
    "@langchain/langgraph-checkpoint-sqlite": "^1.0.3",
    "@langchain/openai": "^1.5.5",
    "@langchain/openrouter": "^0.4.3",
    "@langchain/protocol": "^0.0.18",
    "@langchain/tavily": "1.2.0",
    "cron-parser": "5.6.1",
    "cronstrue": "3.24.0",
    "deepagents": "^1.10.8",
    "ink": "^5.1.0",
    "langchain": "^1.5.3",
    "marked": "^18.0.5",
    "react": "^18.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.10"
  }
}
